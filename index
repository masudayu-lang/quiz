  {t:"PC組み立て",type:"○×",q:"静電気はPCパーツを破損させる可能性がある。",ans:true,exp:"ESD(静電気放電)は半導体を破損させます。作業前に接地するか静電気防止手袋を使用しましょう。"},
  {t:"PC組み立て",type:"○×",q:"CPUグリス(サーマルペースト)は定期的に塗り替えることが推奨される。",ans:true,exp:"サーマルペーストは数年で劣化し冷却効率が低下します。2〜5年での塗り替えが推奨されます。"},
  {t:"PC組み立て",type:"4択",q:"ライザーカードの主な用途は？",opts:["電圧変換","PCIeスロットを延長・方向変換する","冷却効率の改善","USBポートの増設"],ans:1,exp:"ライザーカードはPCIeスロットを延長・垂直方向化するためSFFケースなどで使われます。"},
];

// ===================== STATE =====================
let allQuestions = [...SEED_QUESTIONS];
let sessionQuestions = [], sessionIdx = 0, sessionAnswered = false, sessionLog = [];
let totalCorrect = 0, totalAnswered = 0;
let selectedTopics = new Set(TOPICS);
let generating = false;

// ===================== PASSWORD =====================
function checkPw() {
  const val = document.getElementById('pw-input').value;
  if (val === PASSWORD) {
    sessionStorage.setItem('quiz_auth', '1');
    document.getElementById('pw-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    init();
  } else {
    document.getElementById('pw-error').textContent = 'パスワードが違います。もう一度お試しください。';
    document.getElementById('pw-input').value = '';
    document.getElementById('pw-input').focus();
  }
}

function togglePw() {
  const inp = document.getElementById('pw-input');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}

function logout() {
  sessionStorage.removeItem('quiz_auth');
  document.getElementById('app').style.display = 'none';
  document.getElementById('pw-screen').style.display = 'flex';
  document.getElementById('pw-input').value = '';
  document.getElementById('pw-error').textContent = '';
}

// ===================== INIT =====================
function init() {
  renderTopicBar();
  updateStats();
  renderGenArea();
  document.getElementById('header-sub').textContent = `${allQuestions.length}問収録 — ランダム20問出題`;
}

// ===================== TOPICS =====================
function renderTopicBar() {
  document.getElementById('topic-bar').innerHTML = TOPICS.map(t => {
    const cnt = allQuestions.filter(q => q.t === t).length;
    const act = selectedTopics.has(t);
    return `<button class="topic-pill${act?' active':''}" onclick="toggleTopic('${t}')">${t} <span style="opacity:.6">${cnt}</span></button>`;
  }).join('');
}

function toggleTopic(t) {
  if (selectedTopics.has(t)) { if (selectedTopics.size > 1) selectedTopics.delete(t); }
  else selectedTopics.add(t);
  renderTopicBar();
}

// ===================== STATS =====================
function updateStats() {
  document.getElementById('s-total').textContent = allQuestions.length;
  document.getElementById('s-correct').textContent = totalCorrect;
  document.getElementById('s-rate').textContent = totalAnswered ? Math.round(totalCorrect/totalAnswered*100)+'%' : '-';
}

// ===================== GENERATE =====================
function renderGenArea() {
  const ga = document.getElementById('gen-area');
  if (allQuestions.length >= 200) {
    ga.innerHTML = `<div class="gen-status">200問達成！全テーマをカバーしています</div>`;
    return;
  }
  ga.innerHTML = `<div class="gen-status">現在 ${allQuestions.length}問収録 — AIでさらに追加できます（目標200問）</div>
    <button class="gen-btn" id="gen-btn" onclick="generateMore()">AIで問題を追加生成</button>`;
}

async function generateMore() {
  if (generating) return;
  generating = true;
  const btn = document.getElementById('gen-btn');
  if (btn) btn.disabled = true;
  const ga = document.getElementById('gen-area');
  ga.innerHTML = `<div class="gen-status">AIが問題を生成中です…</div><div class="gen-bar-wrap"><div class="gen-bar-fill" id="gen-fill"></div></div>`;
  let pct = 0;
  const timer = setInterval(() => { pct = Math.min(pct+3,88); const f=document.getElementById('gen-fill'); if(f) f.style.width=pct+'%'; }, 200);
  const existing = allQuestions.map(q=>q.q).slice(0,40).join('\n');
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:1000,
        messages:[{role:'user',content:`マザーボード・PCハードウェア学習クイズ用の問題を20問生成してください。
テーマ(t): ${TOPICS.join('、')}
既存問題(重複不可):\n${existing}
JSON配列のみ返してください(説明文・コードブロック不要):
[{"t":"テーマ名","type":"4択 または ○×","q":"問題文","opts":["A","B","C","D"],"ans":正解インデックス0-3,"exp":"解説"}]
○×の場合はoptsを["○","×"]、ansをtrue/falseにしてください。全て日本語、正確な知識で。`}]
      })
    });
    clearInterval(timer);
    const f=document.getElementById('gen-fill'); if(f) f.style.width='100%';
    const data = await res.json();
    const text = data.content?.map(c=>c.text||'').join('')||'';
    const parsed = JSON.parse(text.replace(/```json|```/g,'').trim());
    parsed.forEach(q => {
      if (q.type==='○×') q.ans = (q.ans===0||q.ans===true||q.ans==='○');
      allQuestions.push(q);
    });
    renderTopicBar(); updateStats();
    document.getElementById('header-sub').textContent = `${allQuestions.length}問収録 — ランダム20問出題`;
    renderGenArea();
    const added = document.createElement('div');
    added.className = 'gen-status'; added.style.marginTop='6px';
    added.textContent = `+${parsed.length}問追加されました`;
    document.getElementById('gen-area').appendChild(added);
  } catch(e) {
    clearInterval(timer);
    document.getElementById('gen-area').innerHTML = `<div class="gen-status" style="color:var(--red-dark)">生成に失敗しました。</div>
      <button class="gen-btn" onclick="generateMore()">再試行</button>`;
  }
  generating = false;
}

// ===================== QUIZ =====================
function shuffle(a) { return [...a].sort(()=>Math.random()-.5); }
function showScreen(id) { document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active')); document.getElementById(id).classList.add('active'); }

function startQuiz() {
  const pool = shuffle(allQuestions.filter(q=>selectedTopics.has(q.t)));
  sessionQuestions = pool.slice(0, Math.min(20, pool.length));
  sessionIdx = 0; sessionLog = [];
  showScreen('screen-quiz');
  renderQ();
}

function renderQ() {
  const q = sessionQuestions[sessionIdx];
  const pct = Math.round(sessionIdx/sessionQuestions.length*100);
  document.getElementById('prog-fill').style.width = pct+'%';
  document.getElementById('q-counter').textContent = `問題 ${sessionIdx+1} / ${sessionQuestions.length}`;
  document.getElementById('q-topic-label').textContent = q.t;
  sessionAnswered = false;
  let html = `<div class="q-card"><span class="q-badge">${q.type} &nbsp; ${q.t}</span><div class="q-text">${q.q}</div>`;
  if (q.type==='4択') {
    html += `<div class="opts">${q.opts.map((o,i)=>`<button class="opt" id="opt-${i}" onclick="ans4(${i})">${o}</button>`).join('')}</div>`;
  } else {
    html += `<div class="tf-row"><button class="tf-btn" id="tf-t" onclick="ansTF(true)">○</button><button class="tf-btn" id="tf-f" onclick="ansTF(false)">×</button></div>`;
  }
  html += `<div id="fb"></div></div>`;
  document.getElementById('quiz-area').innerHTML = html;
}

function ans4(i) {
  if (sessionAnswered) return; sessionAnswered = true;
  const q = sessionQuestions[sessionIdx]; const ok = i===q.ans;
  q.opts.forEach((_,idx)=>{ const b=document.getElementById('opt-'+idx); b.disabled=true; if(idx===q.ans) b.classList.add('correct'); else if(idx===i) b.classList.add('wrong'); });
  record(ok,q);
}

function ansTF(val) {
  if (sessionAnswered) return; sessionAnswered = true;
  const q = sessionQuestions[sessionIdx]; const ok = val===q.ans;
  ['tf-t','tf-f'].forEach(id=>document.getElementById(id).disabled=true);
  document.getElementById(q.ans?'tf-t':'tf-f').classList.add('correct');
  if (!ok) document.getElementById(val?'tf-t':'tf-f').classList.add('wrong');
  record(ok,q);
}

function record(ok,q) {
  totalAnswered++; if(ok) totalCorrect++;
  sessionLog.push({q:q.q,ok,exp:q.exp,ans:q.type==='○×'?(q.ans?'○':'×'):q.opts[q.ans]});
  updateStats();
  const isLast = sessionIdx>=sessionQuestions.length-1;
  document.getElementById('fb').innerHTML = `<div class="feedback ${ok?'ok':'ng'}"><div class="fb-label">${ok?'正解！':'不正解'}</div>${q.exp}</div>
    <button class="next-btn" onclick="${isLast?'showResult()':'nextQ()'}">${isLast?'結果を見る':'次の問題へ'}</button>`;
}

function nextQ() { sessionIdx++; renderQ(); }

function showResult() {
  const score = sessionLog.filter(l=>l.ok).length;
  showScreen('screen-result');
  document.getElementById('r-score').textContent = score;
  const pct = Math.round(score/sessionQuestions.length*100);
  document.getElementById('r-msg').textContent = pct>=90?'素晴らしい！完璧に近い理解です':pct>=70?'よくできました！着実に理解が深まっています':pct>=50?'まだ伸びしろあり！間違えた問題を復習しよう':'もう少し！基礎から見直してみましょう';
  let html = '<div class="log-title">解答ログ</div>';
  sessionLog.forEach((l,i)=>{ html+=`<div class="log-item"><span class="log-icon" style="color:${l.ok?'#639922':'#E24B4A'}">${l.ok?'○':'×'}</span><div><div class="log-q">Q${i+1}. ${l.q}</div><div class="log-ans">正解: ${l.ans} — ${l.exp}</div></div></div>`; });
  document.getElementById('result-log').innerHTML = html;
}

// Auto-login if already authenticated in session
if (sessionStorage.getItem('quiz_auth') === '1') {
  document.getElementById('pw-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  init();
}
document.getElementById('pw-input').addEventListener('keydown', e => { if(e.key==='Enter') checkPw(); });
</script>
